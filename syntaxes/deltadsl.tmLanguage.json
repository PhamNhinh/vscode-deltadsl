{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DeltaDSL",
  "scopeName": "source.deltadsl",
  "fileTypes": ["dsl", "mrd"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#directives" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#input-builders" },
    { "include": "#draw-functions" },
    { "include": "#log-functions" },
    { "include": "#alert-functions" },
    { "include": "#builtin-functions" },
    { "include": "#builtin-series" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.deltadsl",
          "match": "//.*$"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.directive.deltadsl",
          "match": "(@(?:version|name|input|pane))\\b",
          "captures": {
            "1": { "name": "keyword.other.directive.deltadsl" }
          }
        },
        {
          "name": "invalid.illegal.directive.deltadsl",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.color.deltadsl",
          "match": "\"(#[0-9a-fA-F]{3,8}|rgba?\\([^)]*\\))\"",
          "captures": {
            "1": { "name": "constant.other.color.deltadsl" }
          }
        },
        {
          "name": "string.quoted.single.color.deltadsl",
          "match": "'(#[0-9a-fA-F]{3,8}|rgba?\\([^)]*\\))'",
          "captures": {
            "1": { "name": "constant.other.color.deltadsl" }
          }
        },
        {
          "name": "string.quoted.double.deltadsl",
          "begin": "\"",
          "end": "\"|(?<!\\\\)$",
          "patterns": [
            { "name": "constant.character.escape.deltadsl", "match": "\\\\." },
            { "name": "variable.other.placeholder.deltadsl", "match": "\\{\\{[a-zA-Z_][a-zA-Z0-9_]*\\}\\}" }
          ]
        },
        {
          "name": "string.quoted.single.deltadsl",
          "begin": "'",
          "end": "'|(?<!\\\\)$",
          "patterns": [
            { "name": "constant.character.escape.deltadsl", "match": "\\\\." },
            { "name": "variable.other.placeholder.deltadsl", "match": "\\{\\{[a-zA-Z_][a-zA-Z0-9_]*\\}\\}" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.deltadsl",
          "match": "\\b\\d+\\.\\d+\\b|\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.deltadsl",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "constant.language.boolean.deltadsl",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.deltadsl",
          "match": "\\b(na|pi|e)\\b"
        },
        {
          "name": "keyword.control.deltadsl",
          "match": "\\b(if|elseif|else|end|for|to|step|return)\\b"
        },
        {
          "name": "storage.type.function.deltadsl",
          "match": "\\b(fn)\\b"
        },
        {
          "name": "keyword.operator.logical.deltadsl",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.deltadsl",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.deltadsl",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.deltadsl",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "punctuation.separator.comma.deltadsl",
          "match": ","
        },
        {
          "name": "punctuation.accessor.dot.deltadsl",
          "match": "\\."
        }
      ]
    },
    "builtin-series": {
      "patterns": [
        {
          "name": "support.variable.series.ohlcv.deltadsl",
          "match": "\\b(open|high|low|close|volume|hl2|hlc3|ohlc4)\\b"
        },
        {
          "name": "support.variable.series.derivatives.deltadsl",
          "match": "\\b(taker_buy_volume|taker_sell_volume|delta_volume|cvd|open_interest|oi_delta|funding_rate)\\b"
        },
        {
          "name": "support.variable.series.bar.deltadsl",
          "match": "\\b(time|bar_index|bars|last_bar_index|last_bar_time|first_bar_time|barstate_islast)\\b"
        }
      ]
    },
    "input-builders": {
      "patterns": [
        {
          "name": "meta.function.input.deltadsl",
          "match": "\\b(input)\\.(int|float|bool|string|source|color|price)\\b(?=\\s*\\()",
          "captures": {
            "1": { "name": "support.class.input.deltadsl" },
            "2": { "name": "support.function.input.deltadsl" }
          }
        }
      ]
    },
    "draw-functions": {
      "patterns": [
        {
          "name": "support.function.draw.deltadsl",
          "match": "\\b(plotLine|plotDashedLine|plotBand|plotCandle|plotHline|plotDashedHline|plotMarkerUp|plotMarkerDown|plotText|plotLineXY|plotVLine|plotBox|plotLabel|plotPolyline|plotPolygon|plotArrow|plotShape|plotBgColor|plotChar)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.draw.pane.deltadsl",
          "match": "\\b(paneLine|paneDashedLine|paneHline|paneBand|paneCandle|paneFill|paneLabel|paneRange|paneHeight|panePlotLine|panePlotVLine|panePlotBox|panePlotLabel)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.draw.persistent.deltadsl",
          "match": "\\b(labelNew|boxNew|lineNew|polylineNew)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.draw.drawing.deltadsl",
          "match": "\\b(drawingTrendline|drawingHline|drawingFibRet|drawingChannel)\\b(?=\\s*\\()"
        }
      ]
    },
    "alert-functions": {
      "patterns": [
        {
          "name": "support.function.alert.deltadsl",
          "match": "\\b(alertcondition|alert)\\b(?=\\s*\\()"
        }
      ]
    },
    "log-functions": {
      "patterns": [
        {
          "name": "support.function.log.deltadsl",
          "match": "\\b(logInfo|logWarning|logError)\\b(?=\\s*\\()"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "comment": "Math / scalar helpers",
          "name": "support.function.builtin.math.deltadsl",
          "match": "\\b(abs|floor|ceil|round|sign|sqrt|pow|exp|log|log10|sin|cos|tan|asin|acos|atan|atan2|max|min|iff|mask|holdSign|nz|fixnan|isna|na|clamp|lerp)\\b(?=\\s*\\()"
        },
        {
          "comment": "Format / time helpers",
          "name": "support.function.builtin.format.deltadsl",
          "match": "\\b(tostring|padLeft|padRight|year|month|dayofmonth|dayofweek|hour|minute|second|weekofyear)\\b(?=\\s*\\()"
        },
        {
          "comment": "Series operators",
          "name": "support.function.builtin.series.deltadsl",
          "match": "\\b(shift|prev|at|change|crossover|crossunder|cross|highest|lowest|highestbars|lowestbars|sum|cum|cumMax|cumMin|cumProd|scan|accumReset|runStreak|stateMachine|cumReset|maxSinceReset|minSinceReset|barssinceReset|valuewhen|barssince|rising|falling)\\b(?=\\s*\\()"
        },
        {
          "comment": "Moving averages",
          "name": "support.function.builtin.ma.deltadsl",
          "match": "\\b(sma|ema|wma|rma|hma|dema|tema|vwma)\\b(?=\\s*\\()"
        },
        {
          "comment": "Statistics / regression",
          "name": "support.function.builtin.stats.deltadsl",
          "match": "\\b(stdev|variance|dev|normalize|percentrank|percentile|median|correlation|linreg|polyreg2|polyreg2_stderr|zscore)\\b(?=\\s*\\()"
        },
        {
          "comment": "Oscillators",
          "name": "support.function.builtin.osc.deltadsl",
          "match": "\\b(rsi|stoch_k|stoch_d|cci|mfi|willr|mom|roc|macd_line|macd_signal|macd_hist)\\b(?=\\s*\\()"
        },
        {
          "comment": "Volatility / channels",
          "name": "support.function.builtin.vol.deltadsl",
          "match": "\\b(tr|atr|bb_basis|bb_upper|bb_lower|kc_basis|kc_upper|kc_lower|dc_upper|dc_lower|dc_basis)\\b(?=\\s*\\()"
        },
        {
          "comment": "Volume / accumulation",
          "name": "support.function.builtin.volume.deltadsl",
          "match": "\\b(obv|ad|cmf|pvt)\\b(?=\\s*\\()"
        },
        {
          "comment": "Market structure / DMI",
          "name": "support.function.builtin.struct.deltadsl",
          "match": "\\b(pivothigh|pivotlow|pivotAvg|supertrend|supertrend_dir|trail|trail_dir|plus_di|minus_di|adx)\\b(?=\\s*\\()"
        },
        {
          "comment": "Multi-timeframe",
          "name": "support.function.builtin.htf.deltadsl",
          "match": "\\b(htf_resample|htf_new_bar|htf_bucket_start|htf_bars_in_bucket)\\b(?=\\s*\\()"
        },
        {
          "comment": "Dynamic arrays",
          "name": "support.function.builtin.array.deltadsl",
          "match": "\\b(arrNew|arrFrom|arrCopy|arrSize|arrGet|arrFirst|arrLast|arrIndexOf|arrLastIndexOf|arrIncludes|arrPush|arrPop|arrShift|arrUnshift|arrSet|arrInsert|arrRemove|arrClear|arrReverse|arrSort|arrSlice|arrConcat|arrFill|arrSum|arrAvg|arrMin|arrMax|arrMedian|arrStdev|arrVariance|arrToSeries)\\b(?=\\s*\\()"
        },
        {
          "comment": "Colour helpers",
          "name": "support.function.builtin.color.deltadsl",
          "match": "\\b(rgb|rgba|withAlpha|gradient)\\b(?=\\s*\\()"
        },
        {
          "comment": "Drawing introspection",
          "name": "support.function.builtin.introspect.deltadsl",
          "match": "\\b(getUserDrawings)\\b(?=\\s*\\()"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "meta.function-call.deltadsl",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.deltadsl" }
          }
        },
        {
          "comment": "Named keyword-argument inside a call: `color=...`",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?==(?!=))",
          "captures": {
            "1": { "name": "variable.parameter.deltadsl" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.deltadsl",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
