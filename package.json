{
  "name": "deltadsl",
  "displayName": "DeltaDSL — MRD Indicator Script",
  "description": "Official language support for DeltaDSL — syntax highlighting, snippets, and smart editing for MRD Indicators script files (.dsl, .mrd).",
  "version": "0.2.0",
  "publisher": "mrd",
  "license": "SEE LICENSE IN LICENSE.txt",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0F1215",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": ["Programming Languages", "Snippets"],
  "keywords": ["deltadsl", "dsl", "mrd", "trading", "indicator", "syntax-highlighting", "snippets", "autocomplete", "intellisense"],
  "main": "./extension.js",
  "activationEvents": ["onLanguage:deltadsl"],
  "repository": {
    "type": "git",
    "url": "https://github.com/PhamNhinh/vscode-deltadsl.git"
  },
  "bugs": {
    "url": "https://github.com/PhamNhinh/vscode-deltadsl/issues"
  },
  "homepage": "https://github.com/PhamNhinh/vscode-deltadsl#readme",
  "contributes": {
    "languages": [
      {
        "id": "deltadsl",
        "aliases": ["DeltaDSL", "MRD Script", "Delta DSL"],
        "extensions": [".dsl", ".mrd"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "deltadsl",
        "scopeName": "source.deltadsl",
        "path": "./syntaxes/deltadsl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "deltadsl",
        "path": "./snippets/deltadsl.json"
      }
    ]
  }
}
